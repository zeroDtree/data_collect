# Copy to .env and edit.

# external | shared | standalone
DATA_COLLECT_TRAEFIK_MODE=external

PUBLIC_HOST=collect.example.com

# Path to schema file on the host (mounted into the container).
# DATA_COLLECT_SCHEMA_FILE=./schema.yaml

# external and shared modes
TRAEFIK_DOCKER_NETWORK=netbird
TRAEFIK_ENTRYPOINT=websecure
TRAEFIK_CERT_RESOLVER=letsencrypt

# standalone mode only
ACME_EMAIL=admin@example.com
